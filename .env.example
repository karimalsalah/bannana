# ── Database (Neon Serverless Postgres) ─────────────────────────────
# Get this from the Neon dashboard. Better Auth + Drizzle both use it.
DATABASE_URL="postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/banana?sslmode=require"

# ── Better Auth ─────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET="replace-with-32-byte-random-secret"
BETTER_AUTH_URL="http://localhost:3000"

# ── WebAuthn / Passkey (relying party) ──────────────────────────────
RP_ID="localhost"
RP_NAME="The Banana Protocol"
RP_ORIGIN="http://localhost:5173"

# ── Web3 — ERC-4337 Account Abstraction ─────────────────────────────
# Public RPC + a bundler/paymaster URL (e.g. Pimlico, Biconomy, Alchemy AA).
VITE_CHAIN_ID="84532"                       # Base Sepolia testnet
VITE_RPC_URL="https://sepolia.base.org"
VITE_BUNDLER_URL=""                         # ERC-4337 bundler endpoint
VITE_PAYMASTER_URL=""                        # gas sponsorship (feeds gasless $PEEL stakes)
VITE_PEEL_TOKEN_ADDRESS=""                   # $PEEL ERC-20 (leave blank until deployed)
